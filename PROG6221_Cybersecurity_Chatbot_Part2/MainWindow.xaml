<Window x:Class="PROG6221_Cybersecurity_Chatbot_Part2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cybersecurity Awareness Chatbot" 
        Height="550" Width="700"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header with ASCII Art Style -->
        <Border Grid.Row="0" Background="#2D2D2D">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="🛡️ CYBERSECURITY AWARENESS CHATBOT 🛡️"
                           FontSize="22" FontWeight="Bold" 
                           Foreground="Cyan" TextAlignment="Center"
                           FontFamily="Consolas"/>
                <TextBlock Text="Stay Safe Online!"
                           FontSize="14" Foreground="LightGray" 
                           TextAlignment="Center" FontFamily="Consolas"/>
            </StackPanel>
        </Border>

        <!-- Chat Display Area -->
        <ListBox x:Name="ChatDisplay" Grid.Row="1" 
                 Margin="10" Background="#252526" 
                 Foreground="#DCDCDC" FontSize="14"
                 FontFamily="Consolas">
            <ListBox.Resources>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Margin" Value="2"/>
                    <Setter Property="Padding" Value="5"/>
                </Style>
            </ListBox.Resources>
        </ListBox>

        <!-- Input Area -->
        <Border Grid.Row="2" Background="#2D2D2D" 
                Padding="10" Margin="10" CornerRadius="5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="You: " FontWeight="Bold" 
                           Foreground="Magenta" FontSize="14"
                           VerticalAlignment="Center"/>

                <TextBox x:Name="UserInput" Grid.Column="1" 
                         Margin="10,0" Background="#3E3E42" 
                         Foreground="White" FontSize="14"
                         BorderBrush="#555" BorderThickness="1" 
                         Padding="5" KeyDown="UserInput_KeyDown"/>

                <Button x:Name="SendButton" Grid.Column="2" 
                        Content="Send" Width="70" Height="30"
                        Background="#007ACC" Foreground="White" 
                        FontWeight="Bold" Click="SendButton_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>